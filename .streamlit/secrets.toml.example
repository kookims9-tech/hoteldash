# Streamlit Community Cloud → App settings → Secrets
# 이 파일을 secrets.toml로 복사하지 말고, Cloud 대시보드에 아래 형식으로 붙여넣으세요.
# 로컬 개발은 프로젝트 루트의 .env 파일을 사용합니다.

REVENUE_SHEET_ID = "your-revenue-sheet-id"
ROOMS_SHEET_ID = "your-rooms-sheet-id"
HOTEL_NAME = "○○온천관광호텔"
REFRESH_SECONDS = "60"

# Optional — AI 리뷰 요약 (미설정 시 규칙 기반)
# OPENAI_API_KEY = "sk-..."
# OPENAI_MODEL = "gpt-4o-mini"
